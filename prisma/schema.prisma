// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String
  isAdmin     Boolean
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

enum PokemonType {
  Grass
  Fire
  Water
  Lightning
  Fighting
  Psychic
  Colorless
  Darkness
  Metal
  Dragon
  Fairy
}

model Pokemon {
  id                  Int @id @default(autoincrement())
  name                String
  image               String?
  type                PokemonType
  hp                  Int
  attack              Int
  weaknessType        PokemonType
  weaknessDamage      Int
  resistanceType      PokemonType
  resistanceQuantity  Int
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}